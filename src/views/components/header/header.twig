{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int     |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}

{% set important_links = theme.settings.get('important_links') %}

<header class="store-header stronger-header">

    {# Stronger Trust Top Strip #}
    <div class="stronger-header__trust-bar">
        <div class="container stronger-header__trust-inner">
            <div class="stronger-header__trust-item">
                <i class="sicon-shield-check" aria-hidden="true"></i>
                <span>تسوق آمن وموثوق</span>
            </div>

            <div class="stronger-header__trust-item">
                <i class="sicon-shipping-fast" aria-hidden="true"></i>
                <span>تجهيز خلال 1-2 يوم عمل</span>
            </div>

            <div class="stronger-header__trust-item">
                <i class="sicon-credit-card" aria-hidden="true"></i>
                <span>وسائل دفع آمنة</span>
            </div>

            <div class="stronger-header__trust-item stronger-header__trust-contact">
                <salla-contacts is-header></salla-contacts>
            </div>
        </div>
    </div>

    {# Utility Top Nav #}
    <div class="top-navbar stronger-header__top">
        <div class="container stronger-header__top-inner">

            <div class="stronger-header__top-links">
                {% if important_links %}
                    <salla-menu source="footer" topnav></salla-menu>
                {% endif %}
            </div>

            <div class="stronger-header__top-actions">
                {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                    <salla-localization-modal show-trigger></salla-localization-modal>
                {% endif %}

                {% if store.scope %}
                    <button class="btn--rounded-gray stronger-header__scope"
                            onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
                        <i class="sicon-location rtl:ml-1 ltr:mr-1" aria-hidden="true"></i>
                        {{ store.scope.name }}
                    </button>
                {% endif %}
            </div>

        </div>
    </div>

    {# Main Nav #}
    <div id="mainnav" class="main-nav-container stronger-header__main shadow-default bg-white flex items-center">
        <div class="inner bg-inherit w-full">
            <div class="container">

                <div class="stronger-header__main-grid">

                    {# Mobile Menu + Logo #}
                    <div class="stronger-header__brand-side">
                        <a class="lg:hidden mburger mburger--collapse leading-none stronger-header__menu-trigger"
                           href="#mobile-menu"
                           aria-label="Open-menu">
                            <i class="sicon-menu text-primary text-2xl" aria-hidden="true"></i>
                        </a>

                        <a class="navbar-brand stronger-header__brand" href="{{ store.url }}" aria-label="{{ store.name }}">
                            <img fetchpriority="high"
                                 width="100%"
                                 height="100%"
                                 loading="eager"
                                 src="{{ store.logo|cdn(175) }}"
                                 alt="{{ store.name }} logo">

                            {% if is_page('index') %}
                                <h1 class="sr-only">{{ store.name }}</h1>
                            {% else %}
                                <h2 class="sr-only">{{ store.name }}</h2>
                            {% endif %}
                        </a>
                    </div>

                    {# Desktop Search #}
                    <div class="stronger-header__search">
                        <salla-search inline oval height="42"></salla-search>
                    </div>

                    {# Header Actions #}
                    <div class="stronger-header__actions">
                        <salla-user-menu avatar-only show-header show-trigger></salla-user-menu>

                        <salla-cart-summary class="stronger-header__cart">
                            <i slot="icon" class="header-btn__icon icon sicon-shopping-bag"></i>
                        </salla-cart-summary>
                    </div>

                </div>

                {# Desktop Menu Row #}
                <div class="stronger-header__menu-row">
                    <custom-main-menu></custom-main-menu>
                </div>

                {# Mobile Search #}
                <div class="stronger-header__mobile-search">
                    <salla-search inline oval height="40"></salla-search>
                </div>

            </div>
        </div>
    </div>

</header>