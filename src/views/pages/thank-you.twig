{#
| Variable            | Type   | Description                            |
|---------------------|--------|----------------------------------------|
| page                | object |                                        |
| page.title          | string |                                        |
| page.slug           | string |                                        |
| order               | Order  | @see pages/customer/orders/single.twig |
| thank_you           | string |                                        |
| share_message       | string |                                        |
| short_share_message | string |                                        |
#}
{% extends "layouts.master" %}

{% block content %}
    {% hook 'thank-you:start' %}

    <div class="stronger-thankyou-hero">
        <div class="container">
            <nav class="w-full py-5">
                <ol class="list-reset flex items-center text-sm text-primary-reverse">
                    <li>
                        <a href="{{ link('/') }}" class="fix-align text-primary-reverse">
                            {{ trans('common.titles.home') }}
                        </a>
                    </li>
                    <li>
                        <i class="sicon-keyboard_arrow_left mx-2"></i>
                    </li>
                    <li>
                        <span class="fix-align">{{ thank_you_title }}</span>
                    </li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="container stronger-thankyou-page mb-20">

        {# Main Confirmation Card #}
        <section class="stronger-thankyou-card stronger-thankyou-confirmation">
            <div class="stronger-thankyou-confirmation__media rtl:-scale-x-100">
                <img src="{{ 'images/delivery-bro.svg' | asset }}"
                     alt="{{ thank_you_title }}"
                     class="thanks-item opacity-0">
            </div>

            <div class="stronger-thankyou-confirmation__content">
                <div class="stronger-thankyou-status">
                    <i class="sicon-check-circle" aria-hidden="true"></i>
                    <span>تم استلام طلبك بنجاح</span>
                </div>

                <h1 class="thanks-item opacity-0">{{ thank_you_title }}</h1>

                <p class="thanks-item opacity-0">
                    شكرًا لثقتك في {{ store.name }}. تم تسجيل طلبك وسيتم التعامل معه وفق حالة الطلب وطريقة الشحن أو التسليم المحددة.
                </p>

                <div class="stronger-order-reference">
                    <span>{{ trans('pages.thank_you.order_id') }}</span>

                    <salla-button class="relative stronger-order-reference__copy"
                                  onclick="app.copyToClipboard(event)"
                                  color="dark"
                                  shape="link"
                                  data-content="{{ order.reference_id }}">
                        <b>#{{ order.reference_id }}</b>
                        <i class="copy-icon sicon-swap-stroke pointer-events-none rtl:mr-1 ltr:ml-1"></i>
                    </salla-button>
                </div>

                <div class="stronger-thankyou-actions">
                    <salla-button onclick="salla.order.show({order_id:'{{ order.id }}', url:'{{ order.url }}'})">
                        <i class="sicon-newspaper rtl:ml-1 ltr:mr-1"></i>
                        {{ trans('pages.thank_you.order_details') }}
                    </salla-button>

                    <a href="{{ link('/') }}" class="stronger-thankyou-secondary-btn">
                        <i class="sicon-store2" aria-hidden="true"></i>
                        متابعة التسوق
                    </a>
                </div>
            </div>
        </section>

        {# Shopify-like Order Progress #}
        <section class="stronger-thankyou-card stronger-order-progress" aria-label="مراحل معالجة الطلب">
            <div class="stronger-order-progress__item is-active">
                <div class="stronger-order-progress__icon">
                    <i class="sicon-check-circle" aria-hidden="true"></i>
                </div>
                <div>
                    <h3>تم تأكيد الطلب</h3>
                    <p>وصلنا طلبك وتم إنشاء رقم مرجعي للمتابعة.</p>
                </div>
            </div>

            <div class="stronger-order-progress__item">
                <div class="stronger-order-progress__icon">
                    <i class="sicon-packed-box" aria-hidden="true"></i>
                </div>
                <div>
                    <h3>تجهيز الطلب</h3>
                    <p>سيتم تجهيز المنتجات حسب سياسة المتجر وحالة توفرها.</p>
                </div>
            </div>

            <div class="stronger-order-progress__item">
                <div class="stronger-order-progress__icon">
                    {% if order.is_require_shipping ?? true %}
                        <i class="sicon-shipping-fast" aria-hidden="true"></i>
                    {% else %}
                        <i class="sicon-inbox-full" aria-hidden="true"></i>
                    {% endif %}
                </div>
                <div>
                    <h3>الشحن أو التسليم</h3>
                    <p>ستظهر تفاصيل الشحن أو التسليم الرقمي ضمن صفحة تفاصيل الطلب عند توفرها.</p>
                </div>
            </div>

            <div class="stronger-order-progress__item">
                <div class="stronger-order-progress__icon">
                    <i class="sicon-star" aria-hidden="true"></i>
                </div>
                <div>
                    <h3>تجربة ما بعد الطلب</h3>
                    <p>يمكنك التواصل مع الدعم الرسمي لأي استفسار متعلق بطلبك.</p>
                </div>
            </div>
        </section>

        {# Store / Order Trust Summary #}
        <section class="stronger-thankyou-grid">
            <div class="stronger-thankyou-card stronger-thankyou-info-box">
                <div class="stronger-thankyou-info-box__icon">
                    <i class="sicon-lock" aria-hidden="true"></i>
                </div>
                <h3>عملية دفع آمنة</h3>
                <p>تتم عمليات الدفع عبر بوابات دفع آمنة ومعتمدة، ولا يحتفظ المتجر ببيانات البطاقات البنكية.</p>
            </div>

            <div class="stronger-thankyou-card stronger-thankyou-info-box">
                <div class="stronger-thankyou-info-box__icon">
                    <i class="sicon-shipping-fast" aria-hidden="true"></i>
                </div>
                <h3>متابعة الشحن</h3>
                <p>عند شحن الطلب، ستظهر بيانات التتبع أو تفاصيل التسليم ضمن صفحة تفاصيل الطلب أو عبر قنوات المتجر.</p>
            </div>

            <div class="stronger-thankyou-card stronger-thankyou-info-box">
                <div class="stronger-thankyou-info-box__icon">
                    <i class="sicon-return-box" aria-hidden="true"></i>
                </div>
                <h3>سياسات واضحة</h3>
                <p>تخضع طلبات الاسترجاع أو الاستبدال لسياسات المتجر المنشورة وشروط حالة المنتج ونوعه.</p>
            </div>
        </section>

        {% if order.instructions %}
            <section class="stronger-thankyou-card stronger-thankyou-instructions">
                <h2>تعليمات الطلب</h2>
                <article class="article article--main article--small">
                    {{ order.instructions|raw }}
                </article>
            </section>
        {% endif %}

        {% for message in messages %}
            <section class="stronger-thankyou-card stronger-thankyou-message">
                <i class="sicon-info" aria-hidden="true"></i>
                <span>{{ message }}</span>
            </section>
        {% endfor %}

        {% hook 'thank-you:items.start' %}
        {% hook 'thank-you:items.end' %}

        <salla-next-order-coupon></salla-next-order-coupon>

        {# Invoice + Support #}
        <div class="stronger-thankyou-grid stronger-thankyou-grid--two">

            {% if order.email_sent %}
                <section class="stronger-thankyou-card stronger-thankyou-contact-card">
                    <div class="stronger-thankyou-contact-card__icon">
                        <i class="sicon-newspaper-alt" aria-hidden="true"></i>
                    </div>

                    <h3>{{ trans('pages.thank_you.email_sent') }}</h3>

                    {% if order.customer.email %}
                        <p>تم إرسال تفاصيل الطلب إلى البريد التالي:</p>
                        <b>{{ order.customer.email }}</b>
                    {% else %}
                        <p>تم إرسال تفاصيل الطلب إلى بريد العميل المسجل.</p>
                    {% endif %}
                </section>
            {% else %}
                <section id="invoice-form" class="stronger-thankyou-card stronger-thankyou-contact-card">
                    <div class="stronger-thankyou-contact-card__icon">
                        <i class="sicon-newspaper-alt" aria-hidden="true"></i>
                    </div>

                    <h3>{{ trans('pages.thank_you.resend_email') }}</h3>
                    <p>أدخل بريدك الإلكتروني لإعادة إرسال تفاصيل الطلب أو الفاتورة.</p>

                    <form onsubmit="return salla.form.onSubmit('order.sendInvoice', event)">
                        <div class="stronger-thankyou-invoice-form">
                            <input type="email"
                                   class="form-input"
                                   placeholder="your@email.com"
                                   required
                                   name="email">

                            <salla-button type="submit" loader-position="center">
                                <span class="btn__text">{{ trans('blocks.comments.submit') }}</span>
                            </salla-button>
                        </div>
                    </form>
                </section>
            {% endif %}

            <section class="stronger-thankyou-card stronger-thankyou-contact-card">
                <div class="stronger-thankyou-contact-card__icon">
                    <i class="sicon-mail-letter" aria-hidden="true"></i>
                </div>

                <h3>{{ trans('common.titles.support') }}</h3>
                <p>لأي استفسار عن الطلب أو الشحن أو الدفع، تواصل معنا عبر القنوات الرسمية.</p>

                <div class="stronger-thankyou-support-links">
                    {% if store.contacts.mobile %}
                        <a href="tel:{{ store.contacts.mobile }}" class="stronger-thankyou-support-link">
                            <i class="sicon-phone" aria-hidden="true"></i>
                            <b class="unicode">{{ store.contacts.mobile }}</b>
                        </a>
                    {% endif %}

                    {% if store.contacts.whatsapp %}
                        <a href="https://wa.me/{{ store.contacts.whatsapp|replace({' ': '', '+': '', '-': ''}) }}"
                           class="stronger-thankyou-support-link"
                           target="_blank"
                           rel="noopener">
                            <i class="sicon-whatsapp" aria-hidden="true"></i>
                            <b class="unicode">{{ store.contacts.whatsapp }}</b>
                        </a>
                    {% endif %}

                    {% if store.contacts.email %}
                        <a href="mailto:{{ store.contacts.email }}" class="stronger-thankyou-support-link">
                            <i class="sicon-mail" aria-hidden="true"></i>
                            <b>{{ store.contacts.email }}</b>
                        </a>
                    {% endif %}
                </div>
            </section>

        </div>

        {% hook 'thank-you:end' %}
    </div>
{% endblock %}

{% block scripts %}
    <script defer src="{{ 'checkout.js' | asset }}"></script>
{% endblock %}
